# pnpm security/strictness settings
engine-strict=true
strict-peer-dependencies=true

# Lockfile must match package.json in CI
frozen-lockfile=false

# Block all lifecycle scripts from deps by default.
# Add specific packages to package.json -> pnpm.onlyBuiltDependencies to allow.
ignore-scripts=true

# Fail install on audit findings at or above this severity.
audit-level=moderate

# Reproducible resolutions (pick highest satisfying version, ignoring mtime of
# tarballs in the store — mitigates some supply-chain tricks).
resolution-mode=highest
