# Slack Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=xapp-your-app-token

# Slack Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# Optional: path to claude CLI (default: "claude" from PATH)
# CLAUDE_BIN=claude

# Optional: working directory Claude Code operates in (default: current dir)
# CLAUDE_CWD=C:\\Users\\tanaka\\my-first-slack-bot

# Optional: switch cwd per message when a phrase appears in the user's text.
# JSON array, evaluated in order — first matching phrase wins; no match falls back to CLAUDE_CWD.
# CLAUDE_CWD_MAP=[{"phrase":"ギャル","cwd":"C:/Users/takei/gal"}]

# Optional: extra args passed to claude (e.g. --model sonnet)
# CLAUDE_EXTRA_ARGS=

# Optional: allow only specific Slack user IDs (comma or whitespace separated)
# Example: SLACK_USER_WHITELIST=U01234567,U08999999
# If omitted, all users can talk to the bot.
# SLACK_USER_WHITELIST=
